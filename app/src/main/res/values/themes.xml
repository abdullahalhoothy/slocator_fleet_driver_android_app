<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Compose Material3 theme. We use AppCompat as parent so MainActivity (AppCompatActivity) is happy. -->
    <style name="Theme.SLocatorFleetDriver" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/obsidian</item>
        <item name="android:statusBarColor">@color/obsidian</item>
        <item name="android:navigationBarColor">@color/obsidian</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Splash screen using AndroidX SplashScreen API. -->
    <style name="Theme.SLocatorFleetDriver.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/obsidian</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.SLocatorFleetDriver</item>
    </style>

</resources>
