<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- The route file is hosted on a plain-HTTP origin. We restrict cleartext to that
         specific host so the rest of the app stays HTTPS-only. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">37.27.195.216</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
